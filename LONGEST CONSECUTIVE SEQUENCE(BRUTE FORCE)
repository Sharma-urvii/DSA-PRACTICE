// BRUTE FORCE APPROACH:-
// TIME COMPLEXITY :- O(N^2)
// SPACE COMPLEXITY :- O(1)
#include<iostream>
using namespace std;
bool LINEARSEARCH(int arr[],int n,int num){
     for(int i=0;i<n;i++){
         if(arr[i]==num){
           return true;
    }
 }
return false;
}
int LONGESTCONSECUTIVEELEMENTS(int arr[],int n){
      int longest = 1;
     for(int i=0;i<n;i++){
        int cnt = 1;
         int x = arr[i];
      
      while(LINEARSEARCH(arr,n,x+1)){
            x = x+1;
            cnt++;
            if(cnt>longest){
         longest = cnt;
       }
    }
   
} 
return longest;
}
int main(){
int n;
cin>>n;
int arr[n];
for(int i=0;i<n;i++){
    cin>>arr[i];
}
int re = LONGESTCONSECUTIVEELEMENTS(arr,n);
cout<<re;
return 0;
}
