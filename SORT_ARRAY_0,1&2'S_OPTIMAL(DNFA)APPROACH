// OPTIMAL APPROACH :- USING DUTCH NATIONAL FLAG ALGORITHM
// TIME COMPLEXITY :- O(n)    // 1 PASSES
// SPACE COMPLEXITY :- O(1)
#include<bits/stdc++.h>
using namespace std;
void sortarray(int n,vector<int>&arr){
    int low = 0,mid = 0,high = n-1;
    while(mid<=high){
        if(arr[mid]==0){
            swap(arr[low],arr[mid]);
            low++;
            mid++;
        }
        else if(arr[mid]==1){
            mid++;
        }
        else{//if(arr[mid]==2)
            swap(arr[mid],arr[high]);
            high--;
        }
    }
}
int main(){
    int n;
    cin>>n;
    vector<int> arr(n);
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    sortarray(n,arr);
    for(int i=0;i<n;i++){
        cout<<arr[i]<< " ";
    }
}   

