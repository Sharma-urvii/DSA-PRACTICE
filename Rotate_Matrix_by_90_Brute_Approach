Time Complexity = O(n^2)
Space Complexity = O(n^2)
#include<iostream>
#include<vector>
using namespace std;
void rotatematrix(vector<vector<int>>& matrix,int n){
    vector<vector<int>> ans(n,vector<int>(n));
    for(int i = 0;i<n;i++){
        for(int j = 0;j<n;j++){
            ans[j][n-1-i] = matrix[i][j];
        }
    }
    matrix = ans;
}
int main(){
    int n;
    cin>>n;
    vector<vector<int>> matrix(n,vector<int>(n));
    for(int i = 0;i<n;i++){
        for(int j = 0;j<n;j++){
            cin>>matrix[i][j];
        }
    }
    rotatematrix(matrix,n);
    for(int i = 0;i<n;i++){
        for(int j = 0;j<n;j++){
            cout<<matrix[i][j]<<" ";
        }
        cout<<endl;
    }
}
