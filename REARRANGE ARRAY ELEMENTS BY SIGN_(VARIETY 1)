// OPTIMAL SOLUTION :-
// SPACE COMPLEXITY :- O(N)
// TIME COMPLEXITY:- O(N)
#include<iostream>
#include<vector>
using namespace std;
vector<int> rearrangearray(vector<int>&arr,int n){
     vector<int>ans(n,0);
     int posIndex = 0,negIndex = 1;
     for(int i = 0;i<n;i++){
       if(arr[i]<0){
          ans[negIndex] = arr[i];
           negIndex+=2;
         }
       else {
         ans[posIndex]=arr[i];
         posIndex+=2;
         }
       }
  return ans;
  }
int main(){
  int n;
  cin>>n;
  vector<int>arr(n);
  for(int i =0;i<n;i++){
    cin>>arr[i];
    }
  vector<int> result = rearrangearray(arr,n);
  for(int i = 0;i<n;i++){
     cout<<result[i]<< " ";
  }
return 0;
}
